# Supabase Configuration
# Get these from your Supabase project: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only (for admin operations, never exposed to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Public site URL (used for OAuth redirects)
# Set this to your production domain, e.g. https://radia.heronshub.social
NEXT_PUBLIC_SITE_URL=http://localhost:3000
